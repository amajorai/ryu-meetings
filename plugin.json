{
	"id": "com.ryu.meetings",
	"name": "Meetings",
	"version": "1.0.0",
	"description": "Meeting notes: record → live transcript → AI notes, auto-saved into the Meetings Space so they stay editable and RAG-searchable.",
	"engines": {
		"ryu": ">=0.0.1"
	},
	"runnables": [
		{
			"id": "meetings-companion",
			"name": "Meetings",
			"kind": "companion",
			"config": {
				"label": "Meetings",
				"ui_entry": "./dist/index.html",
				"ui_format": "html"
			}
		}
	],
	"sidecars": [
		{
			"name": "ryu-meetings",
			"process": {
				"kind": "local",
				"command": "ryu-meetings",
				"command_env": "RYU_MEETINGS_BIN",
				"port_env": "RYU_MEETINGS_PORT"
			},
			"port": 7998,
			"health_path": "/health",
			"http": {
				"mount": "/api/meetings",
				"public_mount": "/api/meetings",
				"routes": [
					{ "path": "/stream" },
					{ "path": "/detect" },
					{ "path": "/detection-config" },
					{ "path": "/templates" },
					{ "path": "/import" },
					{ "path": "/" },
					{ "path": "/:id" },
					{ "path": "/:id/title" },
					{ "path": "/:id/chunk" },
					{ "path": "/:id/finalize" },
					{ "path": "/:id/transcript" }
				]
			}
		}
	],
	"requires": {
		"apps": [
			{
				"id": "com.ryu.spaces",
				"min_version": "1.0.0"
			}
		],
		"grants": ["spaces:docs"]
	},
	"permission_grants": ["spaces:docs", "meetings:crud"],
	"companion": {
		"label": "Meetings",
		"icon": "mic-01"
	},
	"contributes": {
		"settings_tabs": [
			{
				"id": "meetings.settings",
				"title": "Meetings",
				"scope": "node",
				"view": "meetings"
			}
		],
		"sidebar_sections": [
			{
				"id": "meetings",
				"title": "Meetings",
				"icon": "mic-01",
				"spec": {
					"source": {
						"http": { "method": "GET", "path": "/api/meetings" },
						"items": "meetings"
					},
					"itemTarget": "/meetings/{{item.id}}",
					"itemActions": [
						{
							"id": "delete",
							"label": "Delete",
							"icon": "lucide:trash-2",
							"style": "danger",
							"http": {
								"method": "DELETE",
								"path": "/api/meetings/{{item.id}}"
							}
						}
					]
				}
			}
		]
	}
}
